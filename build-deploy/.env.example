# ── FTP ───────────────────────────────────────────────────────────────
FTP_HOST=ftp.example.com
FTP_USER=example.com
FTP_PASS=your-ftp-password

# ── SERVER PATHS ──────────────────────────────────────────────────────
FTP_ROOT_TEST=/your-test-subdomain.example.com
FTP_ROOT_LIVE=/your-live-domain.example.com

# ── SITE URLS ─────────────────────────────────────────────────────────
# Always use www — non-www 301s drop POST bodies
BASE_URL_TEST=https://www.your-test-subdomain.example.com
BASE_URL_LIVE=https://www.your-live-domain.example.com

# ── TEST CREDENTIALS ──────────────────────────────────────────────────
# Must match F1_ADMIN_EMAIL and F1_ADMIN_PASSWORD defined in config.php.
# Single-quote the password — dotenv treats # as a comment and $ as a
# variable if the value is unquoted, silently truncating the password.
TEST_USER_EMAIL_TEST=f1_admin@helvegpovlsen.dk
TEST_USER_PASSWORD_TEST='your-f1-admin-password'

TEST_USER_EMAIL_LIVE=f1_admin@helvegpovlsen.dk
TEST_USER_PASSWORD_LIVE='your-f1-admin-password'

# ── INTEGRATION ───────────────────────────────────────────────────────
# Must match INTEGRATION_SEED_TOKEN in config.test.php and config.live.php
INTEGRATION_SEED_TOKEN=your-integration-seed-token

# ── CRON ──────────────────────────────────────────────────────────────
# Must match CRON_SECRET in config.test.php
CRON_SECRET=your-cron-secret

# ── DEPLOY ────────────────────────────────────────────────────────────
# Set to true to skip upload (dry run)
DRY_RUN=false
