# Copy this file to .env and fill in real values.
# .env is gitignored — .env.example is committed as a reference.

# ── FTP ───────────────────────────────────────────────────────────────
FTP_HOST=linux350.unoeuro.com
FTP_USER=helvegpovlsen.dk
FTP_PASS=your-ftp-password

# ── SERVER PATHS ──────────────────────────────────────────────────────
FTP_ROOT_TEST=/hpovlsen.dk
FTP_ROOT_LIVE=/formula-1.dk

# ── SITE URLS ─────────────────────────────────────────────────────────
# Always use www — non-www 301s drop POST bodies
BASE_URL_TEST=https://www.hpovlsen.dk
BASE_URL_LIVE=https://www.formula-1.dk

# ── TEST CREDENTIALS ──────────────────────────────────────────────────
TEST_USER_EMAIL_TEST=admin@example.dk
TEST_USER_PASSWORD_TEST=your-test-admin-password

TEST_USER_EMAIL_LIVE=admin@example.dk
TEST_USER_PASSWORD_LIVE=your-live-admin-password

# ── INTEGRATION ───────────────────────────────────────────────────────
# Must match INTEGRATION_SEED_TOKEN in config.test.php and config.live.php
INTEGRATION_SEED_TOKEN=change-me

# ── DEPLOY ────────────────────────────────────────────────────────────
# Set to true to skip upload (dry run)
DRY_RUN=false
