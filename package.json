{
  "scripts": {
    "deploy:test": "node build-deploy/deploy.js test",
    "deploy:live": "node build-deploy/deploy.js live",
    "setup:deploy": "node build-deploy/setup-deployment.js",
    "test:smoke": "node tests/smoke.js",
    "test:e2e:live": "node build-deploy/confirm-live.js && PLAYWRIGHT_HOST_PLATFORM_OVERRIDE=ubuntu22.04-x64 DEPLOY_ENV=live npx playwright test --config tests/playwright.config.js",
    "test:e2e:test": "EMAIL_BACKEND=intercept PLAYWRIGHT_HOST_PLATFORM_OVERRIDE=ubuntu22.04-x64 DEPLOY_ENV=test npx playwright test --config tests/playwright.config.js",
    "test:security": "node tests/security/security.js",
    "test:security:ratelimit": "node tests/security/security.js --ratelimit",
    "test:security:ssllabs": "node tests/security/security.js --ssllabs",
    "test:security:full": "node tests/security/security.js --ssllabs --ratelimit",
    "test:security:live": "node build-deploy/confirm-live.js && DEPLOY_ENV=live node tests/security/security.js",
    "test:security:live:ratelimit": "node build-deploy/confirm-live.js && DEPLOY_ENV=live node tests/security/security.js --ratelimit",
    "test:security:live:ssllabs": "node build-deploy/confirm-live.js && DEPLOY_ENV=live node tests/security/security.js --ssllabs",
    "test:security:live:full": "node build-deploy/confirm-live.js && DEPLOY_ENV=live node tests/security/security.js --ssllabs --ratelimit",
    "test:email:preview": "node tests/email-preview.js",
    "test:unit": "node --test tests/unit/mailer.test.js tests/unit/passkey.test.js && php tests/unit/passkey-harness.php",
    "test:resend": "node build-deploy/verify-resend.js",
    "test:all": "npm run test:smoke && npm run test:unit && npm run test:e2e:test",
    "schema:check": "node build-deploy/schema-check.js test",
    "schema:check:live": "node build-deploy/schema-check.js live",
    "sync:live": "node build-deploy/sync.js",
    "backup:live": "node build-deploy/backup.js",
    "restore:db": "node build-deploy/restore-db.js",
    "nightly": "node build-deploy/nightly-report.js",
    "security:review": "node build-deploy/security-review.js"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "basic-ftp": "^5.0.5",
    "dotenv": "^16.4.5",
    "nodemailer": "^6.10.1",
    "resend": "^6.12.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
